# Fire Detection — environment secrets template
# Copy this file to .env and fill in real values.
# .env is excluded from git (see .gitignore).

# MinIO / S3 credentials for MLflow artifact store
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# API bearer token — protects POST/PUT/DELETE endpoints.
# Leave empty to disable authentication (development only).
API_KEY=

# Telegram bot alerts — get token from @BotFather, chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
