models/*.onnx
models/*.pt
models/*.pth

# Snapshots (runtime data)
snapshots/
apps/web/public/snapshots/

# Database
*.db
*.sqlite

# Docker volumes
postgres_data/
grafana_data/
loki_data/

# Secrets
*.pem
*.key
secrets/

