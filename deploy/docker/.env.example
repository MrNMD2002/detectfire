# Environment variables for Fire & Smoke Detection System
# Copy this file to .env (gitignored) and fill in real values.
# NEVER commit .env with real secrets – only .env.example is safe to commit.
#
# Generate strong secrets with:
#   openssl rand -base64 32   (for JWT_SECRET)
#   openssl rand -hex 32      (for DB_ENCRYPTION_KEY, must be exactly 32 bytes after UTF-8 decode)

# ========================================
# Database Configuration
# ========================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fire_detect
DB_USER=fire_detect
DB_PASSWORD=CHANGE_ME_strong_db_password
# Must be at least 32 characters – used as AES-256-GCM key for RTSP URL encryption
DB_ENCRYPTION_KEY=CHANGE_ME_to_a_secure_random_32byte_key!

# ========================================
# Authentication
# ========================================
# Must be at least 32 characters – used to sign JWT tokens
JWT_SECRET=CHANGE_ME_to_a_long_random_secret_key_here
JWT_EXPIRY_HOURS=24
BCRYPT_COST=12

# ========================================
# Telegram Notifications
# ========================================
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=CHANGE_ME_your_telegram_bot_token
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_RATE_LIMIT=10

# ========================================
# Camera RTSP URLs (credentials stored here, NOT in cameras.yaml)
# ========================================
# Reference these in configs/cameras.yaml as ${CAM_01_RTSP_URL} etc.
CAM_01_RTSP_URL=rtsp://user:CHANGE_ME_password@10.1.1.174:554/cam/realmonitor?channel=1&subtype=0

# ========================================
# Logging
# ========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ========================================
# Monitoring (optional)
# ========================================
GRAFANA_PASSWORD=admin
METRICS_ENABLED=true
METRICS_PORT=9090
